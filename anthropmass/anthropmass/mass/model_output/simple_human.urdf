    <child  link="foot_left"/>
    <origin xyz="0.08745751157402992 0 -0.06745107471942902" rpy="0 0 1.57"/>
    <axis  xyz="0 0 0"/>
  </joint>
  <joint name="torso_bottom_to_upper_leg_right" type="fixed">
